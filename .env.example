# Database
DATABASE_URL=postgresql://calories:calories@localhost:5432/calories

# Auth
JWT_SECRET=your-jwt-secret-here
GOOGLE_CLIENT_ID_WEB=your-google-web-client-id
GOOGLE_CLIENT_ID_IOS=your-google-ios-client-id
GOOGLE_CLIENT_ID_ANDROID=your-google-android-client-id

# Anthropic (Claude LLM)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Clarifai (Food Photo Recognition)
CLARIFAI_PAT=your-clarifai-pat
CLARIFAI_USER_ID=your-clarifai-user-id
CLARIFAI_APP_ID=your-clarifai-app-id

# FatSecret
FATSECRET_CONSUMER_KEY=your-fatsecret-consumer-key
FATSECRET_CONSUMER_SECRET=your-fatsecret-consumer-secret

# Nutritionix
NUTRITIONIX_APP_ID=your-nutritionix-app-id
NUTRITIONIX_APP_KEY=your-nutritionix-app-key

# USDA
USDA_API_KEY=your-usda-api-key

# Server
PORT=3000
NODE_ENV=development

# Admin
ADMIN_EMAILS=admin@example.com

# Feature flags (true/false)
FEATURE_NUTRITIONIX=false
FEATURE_CLARIFAI=true
FEATURE_USDA=true
